# API runtime config (NestJS)

# Server
PORT=3000

# Interactive OpenAPI (Swagger UI) at http://localhost:PORT/api/docs — see docs/sops/SOP_API_MANUAL_TESTING.md
# true | false | unset (unset = on when NODE_ENV is not production)
# API_OPENAPI=true

# Auth
# IMPORTANT: use a long random value in production; keep dev simple.
JWT_SECRET=development-secret

# Database (Docker Compose defaults)
#
# Dialect can be switched for constrained hosts (e.g. cPanel):
# - postgres (default)
# - mysql
# - mariadb
DB_DIALECT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=fordan

# Postgres TLS (managed Postgres)
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# MySQL/MariaDB (common on cPanel)
# If MySQL TCP port is not reachable but a local socket is available, set:
# DATABASE_SOCKET_PATH=/var/lib/mysql/mysql.sock
DATABASE_SOCKET_PATH=

# Schema safety
# - dev default: true (fast iteration)
# - production recommended: false + migrations
DATABASE_SYNCHRONIZE=true

# Seeding
# - dev default: true (seed default accounts)
# - production recommended: false (run seed script explicitly once)
SEED_DEFAULT_USERS=true

# Installer endpoints (dev-only; guard with JWT + RBAC)
INSTALLER_ENABLED=true

# File uploads (future-ready; implement in API when needed)
# STORAGE_DRIVER=local|s3
STORAGE_DRIVER=local

# Local storage (dev only)
LOCAL_UPLOAD_DIR=./uploads

# S3-compatible (prod or MinIO dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=fordan-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Public progressive lead form (POST /api/public/leads)
# UUID of an existing CRM user used to attribute meter rows, timeline, and notes (e.g. first admin from seed).
PUBLIC_LEAD_ACTOR_USER_ID=
# Optional shared secret; when set, require header X-Public-Lead-Secret or body submissionSecret to match.
PUBLIC_LEAD_SUBMISSION_SECRET=
# Rate limit (per IP) for POST /public/leads only
PUBLIC_LEAD_THROTTLE_TTL_MS=60000
PUBLIC_LEAD_THROTTLE_LIMIT=12

# Transactional email (optional — leave SMTP_HOST empty to disable all sends)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_FROM_NAME=Fordan Solar
# Comma-separated — internal notification on each public lead submit
LEAD_NOTIFY_EMAILS=
# true | false — send auto-reply to prospect email after public form submit
PUBLIC_LEAD_SEND_CONFIRMATION_EMAIL=false
# Optional overrides for confirmation email (plain text). Use {firstName} placeholder in body if needed.
# PUBLIC_LEAD_CONFIRMATION_SUBJECT=We received your enquiry
# PUBLIC_LEAD_CONFIRMATION_BODY=Hi {firstName},\n\nThanks for reaching out.

